---
import BaseLayout from "./BaseLayout.astro";
import TagList from "@/components/TagList.astro";
import { formatDate } from "@/utils/date";

interface Props {
  title: string;
  description?: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  lang?: string;
}

const { title, description, date, updatedDate, tags = [], lang } = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="work-post">
    <header class="post-header reveal">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {
          updatedDate && (
            <span class="updated">
              · updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
            </span>
          )
        }
      </div>
      <TagList tags={tags} />
    </header>
    <div class="prose reveal">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .work-post {
    max-width: var(--max-w-prose);
    margin: var(--space-2xl) auto var(--space-3xl);
  }
  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--c-border);
  }
  .post-header h1 {
    font-size: var(--fs-4xl);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }
  .post-meta {
    font-size: var(--fs-sm);
    color: var(--c-text-muted);
    margin-bottom: var(--space-md);
  }
  .updated {
    margin-left: var(--space-xs);
  }

  @media (max-width: 640px) {
    .work-post { margin-top: var(--space-lg); }
    .post-header h1 { font-size: var(--fs-2xl); }
  }
</style>
