---
import { SITE } from "@/utils/site";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const links = [
  SITE.socials.github && {
    href: SITE.socials.github,
    label: "GitHub",
    icon: "github",
  },
  SITE.socials.instagram && {
    href: SITE.socials.instagram,
    label: "Instagram",
    icon: "instagram",
  },
  SITE.socials.linkedin && {
    href: SITE.socials.linkedin,
    label: "LinkedIn",
    icon: "linkedin",
  },
  SITE.socials.xiaohongshu && {
    href: SITE.socials.xiaohongshu,
    label: "Xiaohongshu",
    icon: "xiaohongshu",
  },
  SITE.socials.email && {
    href: SITE.socials.email,
    label: "Email",
    icon: "email",
  },
].filter(Boolean) as { href: string; label: string; icon: string }[];
---

<nav class:list={["social-links", className]} aria-label="Social links">
  {links.map(({ href, label, icon }) => (
    <a
      href={href}
      class="social-btn touch-target"
      target={href.startsWith("mailto:") ? undefined : "_blank"}
      rel={href.startsWith("mailto:") ? undefined : "noopener"}
      aria-label={label}
      title={label}
    >
      {icon === "github" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      )}
      {icon === "instagram" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
        </svg>
      )}
      {icon === "linkedin" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      )}
      {icon === "xiaohongshu" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.53 0h4.712L15.01 6.057h5.265l-1.263 3.3h-5.199L12.53 14.7h-1.322l1.283-5.342H7.2l1.263-3.301h5.29L12.53 0h1.223zm-6.35 6.057H1.725L.462 9.357h4.455L3.634 14.7h1.322L6.24 9.357h5.29L12.793 6.057H6.18zM9.9 16.016h-1.3L5.7 24h1.3l2.9-7.984zm4.2 0h-1.3L9.9 24h1.3l2.9-7.984z"/>
        </svg>
      )}
      {icon === "email" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      )}
    </a>
  ))}
</nav>

<style>
  .social-links {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    color: var(--c-text-muted);
    border: 1px solid var(--c-border);
    background: var(--c-surface);
    transition: color var(--duration-fast) var(--ease-in-out),
      border-color var(--duration-fast) var(--ease-in-out),
      background var(--duration-fast) var(--ease-in-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-in-out);
    text-decoration: none;
  }
  .social-btn:hover {
    color: var(--c-accent);
    border-color: var(--c-accent);
    background: var(--c-accent-subtle);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }
  .social-btn:active {
    transform: translateY(0);
  }
  .social-btn svg {
    flex-shrink: 0;
  }
</style>
